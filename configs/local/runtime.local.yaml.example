database:
  backend: "postgres"
  admin_db:
    host: "localhost"
    port: 5432
    dbname: "postgres"
    user: "postgres"
    password: "replace-with-password"
  workbench_db:
    host: "localhost"
    port: 5432
    dbname: "NeuroGraphIQ_Workbench"
    schema: "workbench"
    user: "postgres"
    password: "replace-with-password"
  unverified_db:
    host: "localhost"
    port: 5432
    dbname: "NeuroGraphIQ_KG_Unverified"
    schema: "neurokg_unverified"
    user: "postgres"
    password: "replace-with-password"
  production_db:
    host: "localhost"
    port: 5432
    dbname: "NeuroGraphIQ_KG"
    schema: "neurokg"
    user: "postgres"
    password: "replace-with-password"

deepseek:
  enabled: false
  api_key: "replace-with-real-key"
  base_url: "https://api.deepseek.com"
  model: "deepseek-chat"
  temperature: 0.2

# Moonshot (Kimi) — 脑区验证中心「Kimi+DeepSeek」双模型路径
moonshot:
  enabled: false
  api_key: ""
  base_url: "https://api.moonshot.cn"
  model: "moonshot-v1-8k"
  temperature: 0.2

pipeline:
  auto_parse_on_upload: true
  auto_extract_on_parse: false
  auto_validate_on_extract: false
  normalize_mode_default: "local"
  validate_mode_default: "local"
  # OWL/RDF compiled ruleset (JSON). See scripts/tools/convert_owl_to_ruleset.py
  ontology_rules:
    enabled: false
    path: "artifacts/ontology/ruleset.json"
    # 抽取阶段写入 review_note.ontology_binding；严格模式下无 term_key 时不允许 confirmed
    bind_on_extract: true
    require_binding_for_confirmed: true
    require_known_terms: false
    stage_policy: "warn" # warn | hard — hard blocks stage_to_unverified on hard-severity issues
    issue_severity:
      parent_not_allowed: "hard"
      invalid_domain_range: "hard"

ui:
  language: "zh-CN"
