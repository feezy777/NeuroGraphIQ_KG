<?xml version="1.0"?>
<rdf:RDF xmlns="http://neurographiq.org/ontology/NeuroGraphIQ_KG/"
     xml:base="http://neurographiq.org/ontology/NeuroGraphIQ_KG/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:NeuroGraphIQ_KG="http://neurographiq.org/ontology/NeuroGraphIQ_KG#">
    <owl:Ontology rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#connection_of_circuit -->

    <owl:ObjectProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#connection_of_circuit">
        <owl:inverseOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_connection"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#ConnectionEntity"/>
        <rdfs:range rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#CircuitEntity"/>
    </owl:ObjectProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#division_of -->

    <owl:ObjectProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#division_of">
        <owl:inverseOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_division"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainDivision"/>
        <rdfs:range rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#Organ"/>
        <rdfs:comment>表示脑大分区与器官之间的从属关系，即某个脑大分区属于某个器官</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_connection -->

    <owl:ObjectProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_connection">
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#CircuitEntity"/>
        <rdfs:range rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#ConnectionEntity"/>
    </owl:ObjectProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_division -->

    <owl:ObjectProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_division">
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#Organ"/>
        <rdfs:range rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainDivision"/>
        <rdfs:comment>表示器官与脑大分区之间的包含关系，即某个器官包含某个脑大分区</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_node -->

    <owl:ObjectProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_node">
        <owl:inverseOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#part_of_circuit"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#CircuitEntity"/>
        <rdfs:range rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainRegion"/>
    </owl:ObjectProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_organ -->

    <owl:ObjectProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_organ">
        <owl:inverseOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#organ_of"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#AnatomicalSystem"/>
        <rdfs:range rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#Organ"/>
        <rdfs:comment>表示解剖系统与器官之间的包含关系，即某个解剖系统包含某个器官</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_region -->

    <owl:ObjectProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_region">
        <owl:inverseOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#region_of"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainDivision"/>
        <rdfs:range rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainRegion"/>
        <rdfs:comment>表示脑大分区与脑区之间的包含关系，即某个脑大分区包含某个脑区</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_source -->

    <owl:ObjectProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_source">
        <owl:inverseOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#source_of"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#ConnectionEntity"/>
        <rdfs:range rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainRegion"/>
        <rdfs:comment>表示某条连接的起始脑区</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_subregion -->

    <owl:ObjectProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_subregion">
        <owl:inverseOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#subregion_of"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainRegion"/>
        <rdfs:range rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainRegion"/>
        <rdfs:comment>表示脑区层级中的包含关系，即主脑区可包含亚脑区，亚脑区可进一步包含 Allen 脑区</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_system -->

    <owl:ObjectProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_system">
        <owl:inverseOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#system_of"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#Organism"/>
        <rdfs:range rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#AnatomicalSystem"/>
        <rdfs:comment>表示个体与解剖系统之间的包含关系，即某个个体具有某个解剖系统</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_target -->

    <owl:ObjectProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_target">
        <owl:inverseOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#target_of"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#ConnectionEntity"/>
        <rdfs:range rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainRegion"/>
        <rdfs:comment>表示连接与目标脑区之间的指向关系，即某条连接指向某个脑区作为终点</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#organ_of -->

    <owl:ObjectProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#organ_of">
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#Organ"/>
        <rdfs:range rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#AnatomicalSystem"/>
        <rdfs:comment>表示器官与解剖系统之间的从属关系，即某个器官属于某个解剖系统</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#part_of_circuit -->

    <owl:ObjectProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#part_of_circuit">
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainRegion"/>
        <rdfs:range rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#CircuitEntity"/>
        <rdfs:comment>表示脑区与回路之间的从属关系，即某个脑区属于某个回路</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#region_of -->

    <owl:ObjectProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#region_of">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainRegion"/>
        <rdfs:range rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainDivision"/>
        <rdfs:comment>表示脑区与脑大分区之间的从属关系，即某个脑区属于某个脑大分区</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#source_of -->

    <owl:ObjectProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#source_of">
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainRegion"/>
        <rdfs:range rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#ConnectionEntity"/>
        <rdfs:comment>表示某个脑区作为某条连接的起始脑区</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#subregion_of -->

    <owl:ObjectProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#subregion_of">
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainRegion"/>
        <rdfs:range rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainRegion"/>
        <rdfs:comment>表示脑区层级中的从属关系，即亚脑区属于主脑区，Allen 脑区属于亚脑区</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#supported_by_circuit -->

    <owl:ObjectProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#supported_by_circuit">
        <owl:inverseOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#supports_circuit"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#CircuitEntity"/>
        <rdfs:range rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#EvidenceEntity"/>
        <rdfs:comment>表示某个回路由某条证据支持，即该证据可作为该回路成立的依据</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#supported_by_connection -->

    <owl:ObjectProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#supported_by_connection">
        <owl:inverseOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#supports_connection"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#ConnectionEntity"/>
        <rdfs:range rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#EvidenceEntity"/>
        <rdfs:comment>表示某条连接由某条证据支持，即该证据可作为该连接成立的依据</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#supports_circuit -->

    <owl:ObjectProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#supports_circuit">
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#EvidenceEntity"/>
        <rdfs:range rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#CircuitEntity"/>
        <rdfs:comment>表示某条证据支持某个回路</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#supports_connection -->

    <owl:ObjectProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#supports_connection">
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#EvidenceEntity"/>
        <rdfs:range rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#ConnectionEntity"/>
        <rdfs:comment>表示某条证据支持某条连接</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#system_of -->

    <owl:ObjectProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#system_of">
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#AnatomicalSystem"/>
        <rdfs:range rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#Organism"/>
        <rdfs:comment>表示解剖系统与个体之间的从属关系，即某个解剖系统属于某个个体</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#target_of -->

    <owl:ObjectProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#target_of">
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainRegion"/>
        <rdfs:range rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#ConnectionEntity"/>
        <rdfs:comment>表示脑区与连接之间的被指向关系，即某个脑区作为某条连接的目标脑区</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_alias -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_alias">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_basic_metadata"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示对象的别名、缩写或其他同义表达，用于名称归一化与检索匹配</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_basic_metadata -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_basic_metadata">
        <rdfs:comment>通用属性父分支</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_brainregion_metadata -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_brainregion_metadata">
        <rdfs:comment>脑区属性的父分支</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_circuit_metadata -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_circuit_metadata">
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#CircuitEntity"/>
        <rdfs:comment>回路属性的父分支</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_cn_name -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_cn_name">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_basic_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示对象的中文名称，用于中文展示和人工理解</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_confidence -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_confidence">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_connection_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#ConnectionEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>表示某条连接成立的置信程度</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_confidence_circuit -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_confidence_circuit">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_circuit_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#CircuitEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>表示某个回路成立的置信程度</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_connection_count -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_connection_count">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_circuit_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#CircuitEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>表示某个回路包含的连接数量</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_connection_metadata -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_connection_metadata">
        <rdfs:comment>连接属性的父分支</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_data_source -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_data_source">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_basic_metadata"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示对象的信息来源或构建来源，例如数据库导入、人工整理、LLM抽取或文献整理</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_description -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_description">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_basic_metadata"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示对象的定义性说明或文本描述，用于解释对象的语义含义</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_direction_label -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_direction_label">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_connection_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#ConnectionEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示连接方向的文字标签或方向说明</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_doi -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_doi">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_evidence_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#EvidenceEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示证据来源对应的 DOI 标识</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_en_name -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_en_name">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_basic_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示对象的英文标准名称，用于统一命名和跨语言对照</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_evidence_metadata -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_evidence_metadata">
        <rdfs:comment>证据属性的父分支</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_evidence_text -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_evidence_text">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_evidence_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#EvidenceEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示支持连接或回路的原始证据文本内容</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_evidence_type -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_evidence_type">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_evidence_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#EvidenceEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示证据来源的类型，例如 paper、abstract、database_record、review 或 manual_note。</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_extraction_method -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_extraction_method">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_connection_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#ConnectionEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示该连接是通过何种方式获得的，例如 LLM、规则抽取、人工整理或数据库导入</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_granularity_level -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_granularity_level">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_brainregion_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainRegion"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示脑区所属的粒度层级</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_id -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_id">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_basic_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示对象的唯一标识符，可用于与数据库记录、外部资源或内部编码进行对应</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_journal -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_journal">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_evidence_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#EvidenceEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示文献证据发表的期刊名称</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_laterality -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_laterality">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_brainregion_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainRegion"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示脑区所在的侧别信息，常用取值包括 left、right、midline 或 bilateral</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_loop_type -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_loop_type">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_circuit_metadata"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#CircuitEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示回路的类型</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_node_count -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_node_count">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_circuit_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#CircuitEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>表示某个回路包含的脑区节点数量</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_ontology_source -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_ontology_source">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_brainregion_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainRegion"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示脑区定义或命名所依据的标准来源，例如 Allen、FreeSurfer 或人工整理</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_organism_metadata -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_organism_metadata">
        <rdfs:comment>个体属性的父分支</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_pmid -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_pmid">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_evidence_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#EvidenceEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示证据来源对应的 PubMed 编号</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_publication_year -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_publication_year">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_evidence_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#EvidenceEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>表示证据来源的发表年份</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_region_category -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_region_category">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_brainregion_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainRegion"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示脑区的解剖类别，例如皮层区、深部核团、脑室、白质、小脑区或脑干区</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_region_code -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_region_code">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_brainregion_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainRegion"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示脑区对应的代码、缩写或标准编号</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_remark -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_remark">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_basic_metadata"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示对象的补充说明、特殊情况或建模备注，用于记录附加信息</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_source_title -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_source_title">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_evidence_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#EvidenceEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示证据来源的标题信息，例如论文标题、书籍标题或数据库记录标题</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_species -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_species">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_organism_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#Organism"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示个体所属的物种类型，用于区分不同生物来源的个体，例如 human、mouse 或 rat</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_status -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_status">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_basic_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示对象当前的状态信息，例如待验证、已验证、草稿或弃用</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_validation_status -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_validation_status">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_connection_metadata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#ConnectionEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示某条连接当前的验证结果状态，例如 raw、validated 或 rejected</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_validation_status_circuit -->

    <owl:DatatypeProperty rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_validation_status_circuit">
        <rdfs:subPropertyOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_circuit_metadata"/>
        <rdfs:domain rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#CircuitEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>表示回路当前的验证结果状态</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#AllenBrainRegion -->

    <owl:Class rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#AllenBrainRegion">
        <rdfs:subClassOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainRegion"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#subregion_of"/>
                <owl:allValuesFrom rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#SubBrainRegion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#MajorBrainRegion"/>
        <owl:disjointWith rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#SubBrainRegion"/>
        <rdfs:comment>Allen脑区</rdfs:comment>
    </owl:Class>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#AllenBrainRegionCircuit -->

    <owl:Class rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#AllenBrainRegionCircuit">
        <rdfs:subClassOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#CircuitEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_connection"/>
                <owl:allValuesFrom rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#AllenBrainRegionConnection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_node"/>
                <owl:allValuesFrom rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#AllenBrainRegion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#MajorBrainRegionCircuit"/>
        <owl:disjointWith rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#SubBrainRegionCircuit"/>
        <rdfs:comment>Allen脑区回路</rdfs:comment>
    </owl:Class>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#AllenBrainRegionConnection -->

    <owl:Class rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#AllenBrainRegionConnection">
        <rdfs:subClassOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#ConnectionEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_source"/>
                <owl:allValuesFrom rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#AllenBrainRegion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_target"/>
                <owl:allValuesFrom rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#AllenBrainRegion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#MajorBrainRegionConnection"/>
        <owl:disjointWith rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#SubBrainRegionConnection"/>
        <rdfs:comment>Allen脑区连接</rdfs:comment>
    </owl:Class>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#AnatomicalEntity -->

    <owl:Class rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#AnatomicalEntity">
        <rdfs:comment>总类</rdfs:comment>
    </owl:Class>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#AnatomicalSystem -->

    <owl:Class rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#AnatomicalSystem">
        <rdfs:subClassOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#AnatomicalEntity"/>
        <rdfs:comment>系统</rdfs:comment>
    </owl:Class>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainDivision -->

    <owl:Class rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainDivision">
        <rdfs:subClassOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#AnatomicalEntity"/>
        <rdfs:comment>表示脑器官下较高层级的解剖分区总类，包括脑叶和非脑叶分区</rdfs:comment>
    </owl:Class>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainLobe -->

    <owl:Class rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainLobe">
        <rdfs:subClassOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainDivision"/>
        <rdfs:comment>脑叶</rdfs:comment>
    </owl:Class>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainRegion -->

    <owl:Class rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainRegion">
        <rdfs:subClassOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#AnatomicalEntity"/>
        <owl:disjointWith rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#CircuitEntity"/>
        <owl:disjointWith rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#ConnectionEntity"/>
        <owl:disjointWith rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#EvidenceEntity"/>
        <rdfs:comment>脑区</rdfs:comment>
    </owl:Class>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#CircuitEntity -->

    <owl:Class rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#CircuitEntity">
        <owl:disjointWith rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#ConnectionEntity"/>
        <owl:disjointWith rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#EvidenceEntity"/>
    </owl:Class>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#ConnectionEntity -->

    <owl:Class rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#ConnectionEntity">
        <owl:disjointWith rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#EvidenceEntity"/>
        <rdfs:comment>连接类</rdfs:comment>
    </owl:Class>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#EvidenceEntity -->

    <owl:Class rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#EvidenceEntity">
        <rdfs:comment>表示用于支持连接或回路成立的证据对象，可对应文献句子、摘要、论文、数据库记录或其他来源信息</rdfs:comment>
    </owl:Class>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#MajorBrainRegion -->

    <owl:Class rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#MajorBrainRegion">
        <rdfs:subClassOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#BrainRegion"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_subregion"/>
                <owl:allValuesFrom rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#SubBrainRegion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#SubBrainRegion"/>
        <rdfs:comment>主脑区</rdfs:comment>
    </owl:Class>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#MajorBrainRegionCircuit -->

    <owl:Class rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#MajorBrainRegionCircuit">
        <rdfs:subClassOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#CircuitEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_connection"/>
                <owl:allValuesFrom rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#MajorBrainRegionConnection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_node"/>
                <owl:allValuesFrom rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#MajorBrainRegion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#SubBrainRegionCircuit"/>
    </owl:Class>
    


    <!-- http://neurographiq.org/ontology/NeuroGraphIQ_KG#MajorBrainRegionConnection -->

    <owl:Class rdf:about="http://neurographiq.org/ontology/NeuroGraphIQ_KG#MajorBrainRegionConnection">
        <rdfs:subClassOf rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#ConnectionEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#has_source"/>
                <owl:allValuesFrom rdf:resource="http://neurographiq.org/ontology/NeuroGraphIQ_KG#MajorBrainRegion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
