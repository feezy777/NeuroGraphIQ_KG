# =============================================================================
# PostgreSQL — local development (keep in sync with DBeaver & scripts)
# See docs/dbeaver_postgres_connection.md
# =============================================================================
# Component variables (used by scripts/db_check_connection.ps1)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=neurographiq_kg_v3_wb
POSTGRES_DB_CANDIDATE=neurographiq_kg_v3_candidate

# SQLAlchemy URLs (must match POSTGRES_* above; special chars in password need URL-encoding)
# Windows: prefer 127.0.0.1 and postgresql+psycopg_async
DATABASE_URL=postgresql+psycopg_async://postgres:postgres@127.0.0.1:5432/neurographiq_kg_v3_wb
CANDIDATE_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/neurographiq_kg_v3_candidate
FINAL_DATABASE_URL=postgresql+psycopg_async://postgres:postgres@127.0.0.1:5432/neurographiq_kg_v3_candidate

# Docker optional: map host 5433 -> container 5432 (see docker-compose.yml)
# POSTGRES_PORT=5433

# =============================================================================
# Application
# =============================================================================
APP_SECRET_KEY=change-this-to-a-random-secret-key
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# File Storage
UPLOAD_DIR=./data/uploads
ARCHIVE_DIR=./data/archive

# LLM - DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# LLM - Kimi (Moonshot)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_DEFAULT_MODEL=moonshot-v1-8k

# Redis (for Celery task queue)
REDIS_URL=redis://localhost:6379/0

# Verbose SQL logging (slow in dev); set true only when debugging SQL
DB_ECHO=false
